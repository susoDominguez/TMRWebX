# Ignore node_modules and other unnecessary directories

api/node_modules/
api/.git/
backend/venv/
backend/**pycache**/
backend/.git/

# Ignore Git-related files

.git/
.gitignore

# Ignore logs

logs/
\*.log
api/app.log

# Ignore Python cache files (if applicable)

**pycache**/
_.pyc
_.pyo

# Ignore IDE and editor temp files

.vscode/
.idea/
_.swp
_.swo
.DS_Store

# Ignore test and coverage files

api/coverage/
api/.nyc_output/
api/\*.tmp

# Ignore Docker-related files (if not needed)

.dockerignore
docker-compose.override.yml

# Ignore environment files

api/.env.local
api/.env.\*.local
